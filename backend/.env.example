# ENViroSwarm Backend Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://enviroswarm:enviroswarm@localhost:5432/enviroswarm

# Security
SECRET_KEY=your-super-secret-key-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:8081

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
