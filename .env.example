# Production Environment Template
# Copy this to .env and fill in your actual values
# NEVER commit .env to git!

# =====================
# Database
# =====================
POSTGRES_USER=enviroswarm
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_32_CHARS
POSTGRES_DB=enviroswarm
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://enviroswarm:REPLACE_WITH_STRONG_PASSWORD_32_CHARS@db:5432/enviroswarm

# =====================
# Redis (for caching & rate limiting)
# =====================
REDIS_URL=redis://redis:6379

# =====================
# Security
# =====================
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =====================
# CORS / Frontend Origins
# =====================
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# =====================
# Deployment
# =====================
ENVIRONMENT=production
DEPLOY_HOST=your-server-ip-or-domain
DEPLOY_USER=root

# =====================
# Monitoring / Alerts
# =====================
ALERT_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
API_URL=https://api.yourdomain.com
WEB_URL=https://yourdomain.com

# =====================
# AWS S3 (for backups)
# =====================
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_S3_BUCKET=enviroswarm-backups
AWS_REGION=us-east-1

# =====================
# Stripe (for payments)
# =====================
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxxxxxx

# =====================
# MQTT
# =====================
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_WEBSOCKET_PORT=9001
